# Copiez ce fichier en .streamlit/secrets.toml en local (jamais commité),
# ou collez son contenu dans le gestionnaire de secrets de Streamlit Cloud.
#
# Ce même fichier sert pour le déploiement de démo (repo public, données
# factices) et pour le déploiement de production (repo privé, vraies
# données) : seules les valeurs ci-dessous changent d'un déploiement à
# l'autre (repo cible, token, mots de passe).

[github]
token = "ghp_votr•••••••••••••••••••••••"
repo = "votre-org/suivi-vues"
branch = "main"

# Optionnel : nécessaire uniquement pour activer la collecte automatique YouTube
# (créez une clé sur https://console.cloud.google.com/apis/credentials après avoir
# activé "YouTube Data API v3"). Sans clé, les URLs YouTube resteront en erreur
# lors de la collecte et devront être suivies manuellement en attendant.
[youtube]
api_key = "votre_cle_api_youtube_data_v3"

[auth.cookie]
name = "suivi_vues_auth"
key = "changez-moi-par-une-chaine-aleatoire-longue"
expiry_days = 30

# Générez les mots de passe hashés avec :
#   python -c "import streamlit_authenticator as stauth; print(stauth.Hasher().hash('votre_mot_de_passe'))"
[auth.credentials.usernames.admin]
name = "Admin"
password = "$2b$12$remplacez_par_le_hash_genere"
role = "editeur"

[auth.credentials.usernames.lecteur]
name = "Lecteur"
password = "$2b$12$remplacez_par_le_hash_genere"
role = "lecteur"
